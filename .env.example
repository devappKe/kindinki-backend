# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration 
# (Keep MONGO_URI if you are using both, otherwise you can remove it)
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/YourDb?retryWrites=true&w=majority
DATABASE_URL=postgresql://postgres:your_db_password@db.your_project.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Supabase Configuration
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_WEBHOOK_SECRET=your_webhook_secret

# Security
BCRYPT_SALT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100